default_platform(:ios)

platform :ios do

  # Bump build number to git commit count (deterministic, no conflicts)
  lane :set_build_number do
    count = sh("git rev-list --count HEAD").strip
    increment_build_number(build_number: count, xcodeproj: "AmuxApp.xcodeproj")
  end

  # One-time: create certs + provisioning profiles (run via CI dispatch)
  lane :create_certs do
    setup_ci if ENV["CI"]

    api_key = app_store_connect_api_key(
      key_id:        ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id:     ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content:   ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true
    )

    match(type: "appstore", api_key: api_key, readonly: false)
  end

  # CI: fetch certs + build + upload to TestFlight
  lane :beta do
    setup_ci if ENV["CI"]

    api_key = app_store_connect_api_key(
      key_id:        ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id:     ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content:   ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true
    )

    match(type: "appstore", api_key: api_key, readonly: true)

    set_build_number

    build_app(
      scheme: "AmuxApp",
      configuration: "Release",
      export_method: "app-store",
      xcargs: "-skipPackagePluginValidation -allowProvisioningUpdates"
    )

    upload_to_testflight(api_key: api_key, skip_waiting_for_build_processing: true)
  end

  # Promote latest TestFlight build to App Store (run manually)
  lane :release do
    api_key = app_store_connect_api_key(
      key_id:        ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id:     ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content:   ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true
    )

    deliver(
      api_key: api_key,
      submit_for_review: true,
      automatic_release: true,
      force: true,
      skip_screenshots: true,  # set to false once you have screenshots
      skip_metadata: false
    )
  end

end
